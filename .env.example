# PuckQ environment variables.
# Copy to .env.local (gitignored) for local dev, or set these in your host
# (e.g. Railway → service → Variables) for production. Never commit real values.

# ── Database ──────────────────────────────────────────────────────────────
# Path to the SQLite file. Defaults to ./puckq.db in the working directory.
# On Railway, point this at the mounted volume, e.g. /data/puckq.db
DATABASE_FILE=

# ── Admin auth — Auth.js + GitHub (gates /admin) ──────────────────────────
# Required. Session signing secret. Generate one with:
#   npx auth secret        (writes it to .env.local)
#   openssl rand -base64 33
AUTH_SECRET=

# GitHub OAuth app credentials:
#   github.com → Settings → Developer settings → OAuth Apps → New OAuth App
#   Authorization callback URL must be  <site>/api/auth/callback/github
#   (e.g. http://localhost:3000/api/auth/callback/github for local)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# The single GitHub username allowed to sign in to /admin (case-insensitive).
# If unset, nobody can sign in (fail-closed).
ADMIN_GITHUB_LOGIN=

# Required on non-Vercel hosts (e.g. Railway). Set to: true
# Not needed for local dev (localhost is trusted automatically).
AUTH_TRUST_HOST=

# ── Daily data refresh (hosted) ───────────────────────────────────────────
# Shared secret that protects POST /api/refresh (the current-season refresh the
# daily GitHub Actions cron triggers). Generate any long random string, e.g.
#   openssl rand -hex 32
# Leave unset locally (you can just run `npm run ingest:current`); the endpoint
# returns 503 until it's set. The GitHub repo needs matching secrets REFRESH_URL
# (the site base URL) and REFRESH_TOKEN.
REFRESH_TOKEN=

# ── Optional ──────────────────────────────────────────────────────────────
# Enables the "AI summary" writing aid in the recap admin (Google Gemini, free
# tier — get a key at aistudio.google.com, no credit card). The panel shows
# "enable" when unset. NOTE: recap prose is always human-written; this only
# produces a private data brief you write from.
GEMINI_API_KEY=
# Optional: override the Gemini model (default: gemini-2.5-flash).
# GEMINI_MODEL=

# Enables AI-written player blurbs in `npm run summaries` (Anthropic). Falls
# back to a deterministic rule-based summary if unset.
ANTHROPIC_API_KEY=
